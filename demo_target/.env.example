# demo_target 环境变量配置模板
# 本文件仅包含占位符，请勿在生产中使用这些假值
# 复制本文件为 .env 并填入实际值，或通过其他方式注入环境变量

# 应用 API 密钥（占位符）
MYAPP_API_KEY=your_api_key_here

# 数据库连接字符串（占位符）
# 格式：postgres://username:password@host:port/database
DATABASE_URL=postgres://user:password@db.example.invalid:5432/appdb

# 飞书 Webhook URL（占位符）
# 格式：https://open.feishu.cn/open-apis/bot/v2/hook/YOUR_WEBHOOK_TOKEN
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/your_webhook_token
